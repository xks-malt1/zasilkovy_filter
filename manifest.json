{
  "manifest_version": 3,
  "name": "Zásielkový filter",
  "version": "1.1",
  "description": "Zobrazí prehľad zásielok podľa dátumu a klienta.",
  "permissions": ["scripting", "activeTab"],
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "Spustiť zásielkový filter"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
